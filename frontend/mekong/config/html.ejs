<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <title>Mekong - Composable Data Workspace</title>
    <meta name="description" content="Enterprise data platform with microfrontend architecture" />

    <!-- PWA manifest -->
    <link rel="manifest" href="/manifest.webmanifest" />

    <!-- Theme color (Safari address bar / Android status bar) -->
    <meta name="theme-color" content="#0f172a" />

    <!-- iOS PWA meta tags -->
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="apple-mobile-web-app-title" content="Mekong" />

    <!-- iOS home-screen icons -->
    <link rel="apple-touch-icon" href="/icons/icon-180.png" />
    <link rel="apple-touch-icon" sizes="152x152" href="/icons/icon-152.png" />
    <link rel="apple-touch-icon" sizes="167x167" href="/icons/icon-180.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/icons/icon-180.png" />

    <!-- Favicon -->
    <link rel="icon" type="image/png" sizes="32x32" href="/icons/icon-96.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/icons/icon-72.png" />

    <!-- iOS splash screens (generated dynamically via JS) -->
    <meta name="mobile-web-app-capable" content="yes" />

    <% for (file of compilation.chunks.filter(chunk => chunk.isOnlyInitial()).map(chunk => chunk.files).reduce((acc, val) => acc.concat(val), []).filter(file => /\.css$/.test(file))) { %>
    <link rel="stylesheet" href="<%= file %>" />
    <% } %>
</head>
<body>
    <div id="root"></div>
    <% for (file of compilation.chunks.filter(chunk => chunk.isOnlyInitial()).map(chunk => chunk.files).reduce((acc, val) => acc.concat(val), []).filter(file => /\.js$/.test(file))) { %>
    <script src="<%= file %>"></script>
    <% } %>
</body>
</html>
